# ---------------------------------------------------------------------------
# XM Real Estate — apps/web environment variables
# ---------------------------------------------------------------------------
# Copy this file to `apps/web/.env` and fill in real values for local dev.
# In production (Vercel etc.) set these in the hosting provider's project
# settings — never commit real secrets to the repo.
# ---------------------------------------------------------------------------

# --- Database --------------------------------------------------------------
# Neon Postgres connection string. Required for any database-backed feature
# (auth, inquiries, notifications, timeline). The app boots without it but
# every DB call will fail.
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# --- Authentication (Auth.js / @hono/auth-js) ------------------------------
# Random secret used to sign session JWTs. Generate with:
#   openssl rand -base64 32
# If unset, the /api/auth/* routes return null and auth is effectively off.
AUTH_SECRET=

# Public base URL Auth.js will use to build callback URLs.
# Local dev:  http://localhost:5000
# Production: https://your-domain.com  (Vercel: set to your deployment URL)
AUTH_URL=http://localhost:5000

# --- CORS ------------------------------------------------------------------
# Optional. Comma-separated list of origins allowed to call the API.
# Leave empty to skip the CORS middleware entirely (same-origin only).
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# --- Standard Node environment --------------------------------------------
# Vite/Node sets this automatically (`development` in dev, `production` in
# the built output). Only set explicitly if you need to override.
# NODE_ENV=development

# ---------------------------------------------------------------------------
# Create.xyz integrations proxy (apps/web/__create/index.ts)
# ---------------------------------------------------------------------------
# These are only needed if you actually call routes under /integrations/*
# (the Hono server proxies them to the Create.xyz integrations API). If you
# do not use Create.xyz integrations, leave them empty — the proxy route
# falls back to https://www.create.xyz for the base URL.
NEXT_PUBLIC_CREATE_BASE_URL=
NEXT_PUBLIC_CREATE_API_BASE_URL=
NEXT_PUBLIC_CREATE_HOST=
NEXT_PUBLIC_PROJECT_GROUP_ID=

# Set to "DEVELOPMENT" to enable the dev-only simulated social sign-in
# provider (Google/Facebook/Twitter/Apple via email-only credentials). Leave
# empty in production.
NEXT_PUBLIC_CREATE_ENV=

# ---------------------------------------------------------------------------
# Smoke check script (apps/web/scripts/check-pages.mjs) — dev tooling only.
# You almost never need to set these by hand; the script defaults are fine.
# ---------------------------------------------------------------------------
# CHECK_BASE_URL=http://localhost:5051
# CHECK_PORT=5051
# PLAYWRIGHT_BROWSERS_PATH is auto-set by the script to apps/web/.playwright-browsers
